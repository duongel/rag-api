# ── Required ───────────────────────────────────────────────────────────────
# Which data sources to index: all | obsidian | paperless
DATA_SOURCES=all

# Path to the Obsidian vault (directory containing .md files)
# Not required when DATA_SOURCES=paperless
VAULT_PATH=/path/to/your/vault

# ── Ollama ─────────────────────────────────────────────────────────────────
# Default: internal container on rag-network
# If Ollama runs as another Docker service on the same network, point this at it.
OLLAMA_URL=http://ollama:11434
EMBED_MODEL=bge-m3
# The embedding model is pulled into Ollama automatically if missing.
# Set to false to require the model to be present beforehand.
# EMBED_MODEL_AUTO_PULL=true
# Batch size for embedding document chunks during indexing.
# EMBED_BATCH=64
# Task prefixes are auto-selected from the model name (nomic-* needs them,
# bge-m3 and most others do not). Override only for exotic models.
# EMBED_DOC_PREFIX=auto
# EMBED_QUERY_PREFIX=auto

# ── Indexing performance (optional) ────────────────────────────────────────
# Worker threads used during a full reindex. Embedding runs in parallel across
# workers while DB writes are serialized. Higher = faster on multi-core CPUs at
# the cost of more Ollama load. Set to 1 to disable concurrency.
# OBSIDIAN_REINDEX_WORKERS=8
# PAPERLESS_REINDEX_WORKERS=8
# PAPERLESS_PREFETCH_WORKERS=8
# Chunks embedded per Ollama request (see EMBED_BATCH above).
#
# The worker counts only help if Ollama serves requests concurrently. For the
# bundled local Ollama container set OLLAMA_NUM_PARALLEL to roughly match your
# worker count, and keep the model resident with OLLAMA_KEEP_ALIVE.
# OLLAMA_NUM_PARALLEL=4
# OLLAMA_KEEP_ALIVE=30m
# OLLAMA_TIMEOUT_SECONDS=180

# ── Reranking (optional) ───────────────────────────────────────────────────
# A cross-encoder reranker reorders the top candidates for much better
# precision. Disabled by default: start the service with
#   docker compose --profile reranker up
# then set RERANK_ENABLED=true.
# RERANK_ENABLED=false
# RERANK_URL=http://reranker:80
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_CANDIDATES=30
# Truncate each candidate to N chars before reranking (0 = off). Lower values
# keep CPU-only rerankers fast; 512 balances speed and relevance signal.
# RERANK_DOC_CHARS=512

# ── HNSW index tuning (optional) ───────────────────────────────────────────
# Higher values improve recall at the cost of memory and build/query time.
# Defaults suit modern multi-core hardware. Changing HNSW_M or
# HNSW_CONSTRUCTION_EF requires a full re-index to take effect.
# HNSW_M=32
# HNSW_CONSTRUCTION_EF=200
# HNSW_SEARCH_EF=128

# ── API ────────────────────────────────────────────────────────────────────
# Public URL of this API (used in SKILL.md, OpenAPI spec, and agent integration)
# Local: http://localhost:8484
# Behind a reverse proxy: https://rag.example.com
PUBLIC_URL=http://localhost:8484

# ── Access mode ────────────────────────────────────────────────────────────
# `host` publishes the API on the host via docker-compose.host.yml.
# `internal` keeps the API available only on the Docker network.
ACCESS_MODE=host
# Host bind settings used only with docker-compose.host.yml
HOST_BIND_ADDRESS=127.0.0.1
HOST_PORT=8484

# ── API access control ─────────────────────────────────────────────────────
# AUTH_REQUIRED=true  → bearer token required on all data endpoints (recommended)
# AUTH_REQUIRED=false → no authentication (trusted network or local testing only)
AUTH_REQUIRED=true
# Generate a long random token, for example:
# openssl rand -hex 32
API_BEARER_TOKEN=replace-with-a-long-random-token

# ── Docker network ─────────────────────────────────────────────────────────
# External network where Ollama (and optionally Paperless) are reachable.
# Leave empty if everything runs on the internal rag-network.
# DOCKER_NETWORK=my-external-network

# ── Paperless-NGX (optional) ──────────────────────────────────────────────
# All documents are fetched via the Paperless REST API.
# Requires a Paperless API token (Settings → API Tokens).
# PAPERLESS_URL=http://paperless-webserver:8000
# PAPERLESS_TOKEN=
# PAPERLESS_PUBLIC_URL=https://paperless.example.com
