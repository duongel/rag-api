# ── Required ───────────────────────────────────────────────────────────────
# Which data sources to index: all | obsidian | paperless
DATA_SOURCES=all

# Path to the Obsidian vault (directory containing .md files)
# Not required when DATA_SOURCES=paperless
VAULT_PATH=/path/to/your/vault

# ── Ollama ─────────────────────────────────────────────────────────────────
# Default: internal container on rag-network
# If Ollama runs as another Docker service on the same network, point this at it.
OLLAMA_URL=http://ollama:11434
EMBED_MODEL=nomic-embed-text

# ── API ────────────────────────────────────────────────────────────────────
# Public URL of this API (used in SKILL.md, OpenAPI spec, and agent integration)
# Local: http://localhost:8484
# Behind a reverse proxy: https://rag.example.com
PUBLIC_URL=http://localhost:8484

# ── Access mode ────────────────────────────────────────────────────────────
# `host` publishes the API on the host via docker-compose.host.yml.
# `internal` keeps the API available only on the Docker network.
ACCESS_MODE=host
# Host bind settings used only with docker-compose.host.yml
HOST_BIND_ADDRESS=127.0.0.1
HOST_PORT=8484

# ── API access control ─────────────────────────────────────────────────────
# AUTH_REQUIRED=true  → bearer token required on all data endpoints (recommended)
# AUTH_REQUIRED=false → no authentication (trusted network or local testing only)
AUTH_REQUIRED=true
# Generate a long random token, for example:
# openssl rand -hex 32
API_BEARER_TOKEN=replace-with-a-long-random-token

# ── Docker network ─────────────────────────────────────────────────────────
# External network where Ollama (and optionally Paperless) are reachable.
# Leave empty if everything runs on the internal rag-network.
# DOCKER_NETWORK=my-external-network

# ── Paperless-NGX (optional) ──────────────────────────────────────────────
# All documents are fetched via the Paperless REST API.
# Requires a Paperless API token (Settings → API Tokens).
# PAPERLESS_URL=http://paperless-webserver:8000
# PAPERLESS_TOKEN=
# PAPERLESS_PUBLIC_URL=https://paperless.example.com
